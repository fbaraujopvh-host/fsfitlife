---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { products } from '../../data/products';

export function getStaticPaths() {
  return products.map((product) => ({
    params: { slug: product.slug },
    props: { product },
  }));
}

const { product } = Astro.props;

const related = products
  .filter((p) => p.category === product.category && p.id !== product.id)
  .slice(0, 3);
---

<Layout title={`${product.name} — FS FitLife`} description={product.description}>
  <Header />
  <main>
    <nav class="breadcrumb">
      <div class="container">
        <a href="/">← Voltar para a vitrine</a>
      </div>
    </nav>

    <section class="product">
      <div class="container grid">
        <div class="gallery">
          {product.badge && <div class="badge">{product.badge}</div>}
          <div class="discount-tag">{product.discount}</div>
          <img src={product.image} alt={product.name} />
        </div>

        <div class="info">
          <span class="category-pill">{product.category}</span>
          <h1>{product.name}</h1>
          <p class="tagline">{product.tagline}</p>

          <div class="rating">
            <span class="stars">{"★".repeat(Math.floor(product.rating))}{"☆".repeat(5 - Math.floor(product.rating))}</span>
            <span class="rating-value">{product.rating}</span>
            <span class="review-count">({product.reviews.toLocaleString('pt-BR')} avaliações)</span>
          </div>

          <p class="description">{product.longDescription}</p>

          <ul class="benefits">
            {product.benefits.map((b) => (
              <li><span class="check">✓</span>{b}</li>
            ))}
          </ul>

          <div class="how-to-use">
            <h3>Como usar</h3>
            <p>{product.howToUse}</p>
          </div>

          <div class="buy-box">
            <div class="pricing">
              <span class="original-price">{product.originalPrice}</span>
              <span class="current-price">{product.price}</span>
            </div>
            <a
              href={product.affiliateUrl}
              class="buy-btn"
              target="_blank"
              rel="nofollow sponsored noopener noreferrer"
            >
              🛒 COMPRAR AGORA
            </a>
            <p class="guarantee">🔒 Compra 100% segura • 30 dias de garantia</p>
            <p class="disclosure">Este é um link de afiliado. Ao comprar através dele, você apoia nosso trabalho sem custo extra para você.</p>
          </div>
        </div>
      </div>
    </section>

    {related.length > 0 && (
      <section class="related">
        <div class="container">
          <h2>Você também pode gostar</h2>
          <div class="related-grid">
            {related.map((p) => (
              <a href={`/produto/${p.slug}`} class="related-card">
                <div class="related-image">
                  <img src={p.image} alt={p.name} loading="lazy" />
                </div>
                <div class="related-body">
                  <strong>{p.name}</strong>
                  <span class="related-price">{p.price}</span>
                </div>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}
  </main>
  <Footer />
</Layout>

<style>
  .breadcrumb {
    padding: 1.25rem 0;
    border-bottom: 1px solid #1f1f1f;
  }
  .breadcrumb a {
    color: var(--gray-400);
    font-size: 0.9rem;
    transition: color 0.2s;
  }
  .breadcrumb a:hover { color: var(--primary); }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .product { padding: 3rem 0 4rem; }
  .grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: start;
  }
  @media (max-width: 860px) {
    .grid { grid-template-columns: 1fr; gap: 2rem; }
  }

  .gallery {
    position: relative;
    border-radius: 20px;
    overflow: hidden;
    background: #111;
    border: 1px solid #2a2a2a;
    aspect-ratio: 4/3;
  }
  .gallery img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .badge {
    position: absolute;
    top: 1.25rem;
    left: 1.25rem;
    z-index: 5;
    background: var(--primary);
    color: white;
    font-size: 0.78rem;
    font-weight: 700;
    padding: 0.35rem 0.9rem;
    border-radius: 999px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }
  .discount-tag {
    position: absolute;
    top: 1.25rem;
    right: 1.25rem;
    z-index: 5;
    background: var(--accent);
    color: #000;
    font-size: 0.85rem;
    font-weight: 800;
    padding: 0.35rem 0.75rem;
    border-radius: 8px;
  }

  .info { display: flex; flex-direction: column; gap: 1rem; }
  .category-pill {
    display: inline-block;
    width: fit-content;
    background: rgba(113, 192, 55,0.12);
    border: 1px solid rgba(113, 192, 55,0.35);
    color: var(--primary);
    font-size: 0.78rem;
    font-weight: 600;
    padding: 0.3rem 0.85rem;
    border-radius: 999px;
  }
  h1 {
    font-size: clamp(1.6rem, 3.5vw, 2.4rem);
    font-weight: 900;
    line-height: 1.2;
    letter-spacing: -0.5px;
  }
  .tagline {
    font-size: 1rem;
    font-weight: 600;
    color: var(--gray-200);
  }
  .rating {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    flex-wrap: wrap;
  }
  .stars { color: var(--accent); font-size: 1rem; }
  .rating-value { font-weight: 700; font-size: 0.95rem; }
  .review-count { color: var(--gray-400); font-size: 0.85rem; }

  .description {
    color: var(--gray-400);
    line-height: 1.75;
    font-size: 0.98rem;
  }

  .benefits {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin: 0.25rem 0;
  }
  .benefits li {
    font-size: 0.92rem;
    color: var(--gray-200);
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }
  .check { color: #22c55e; font-weight: 700; }

  .how-to-use {
    background: #141414;
    border: 1px solid #222;
    border-radius: 14px;
    padding: 1.1rem 1.25rem;
  }
  .how-to-use h3 {
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: var(--gray-400);
    margin-bottom: 0.4rem;
  }
  .how-to-use p { font-size: 0.9rem; color: var(--gray-200); line-height: 1.6; }

  .buy-box {
    margin-top: 0.5rem;
    padding: 1.5rem;
    background: linear-gradient(145deg, #1a1a1a, #141414);
    border: 1px solid #2a2a2a;
    border-radius: 16px;
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }
  .pricing {
    display: flex;
    align-items: baseline;
    gap: 0.85rem;
  }
  .original-price {
    color: var(--gray-600);
    text-decoration: line-through;
    font-size: 1rem;
  }
  .current-price {
    font-size: 2.1rem;
    font-weight: 900;
    color: var(--white);
  }
  .buy-btn {
    display: block;
    background: linear-gradient(135deg, var(--primary), var(--primary-dark));
    color: white;
    font-size: 1.1rem;
    font-weight: 800;
    text-align: center;
    padding: 1.1rem;
    border-radius: 12px;
    letter-spacing: 0.5px;
    transition: all 0.25s ease;
    box-shadow: 0 4px 20px rgba(113, 192, 55,0.3);
  }
  .buy-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 30px rgba(113, 192, 55,0.5);
  }
  .buy-btn:active { transform: translateY(0); }
  .guarantee {
    text-align: center;
    font-size: 0.8rem;
    color: var(--gray-400);
  }
  .disclosure {
    text-align: center;
    font-size: 0.72rem;
    color: var(--gray-600);
    font-style: italic;
  }

  .related {
    background: #0a0a0a;
    padding: 3.5rem 0;
    border-top: 1px solid #1f1f1f;
  }
  .related h2 {
    font-size: clamp(1.4rem, 3vw, 1.9rem);
    font-weight: 900;
    margin-bottom: 1.75rem;
  }
  .related-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1.25rem;
  }
  .related-card {
    display: block;
    background: #141414;
    border: 1px solid #222;
    border-radius: 14px;
    overflow: hidden;
    transition: border-color 0.25s, transform 0.25s;
  }
  .related-card:hover {
    border-color: var(--primary);
    transform: translateY(-3px);
  }
  .related-image {
    aspect-ratio: 4/3;
    overflow: hidden;
    background: #111;
  }
  .related-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .related-body {
    padding: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }
  .related-body strong { font-size: 0.92rem; line-height: 1.35; }
  .related-price { font-weight: 800; color: var(--primary); }
</style>
