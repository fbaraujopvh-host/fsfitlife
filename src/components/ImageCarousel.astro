---
import { products } from '../data/products';
---

<section class="img-carousel-section">
  <div class="label">
    <span class="pulse"></span>
    Produtos em destaque agora
  </div>

  <div class="track-wrapper">
    <div class="track" id="imgTrack">
      {/* Duplicamos para loop infinito */}
      {[...products, ...products].map((p, i) => (
        <a href={`/produto/${p.slug}`} class="slide" title={p.name}>
          <div class="img-wrap">
            <img src={p.image} alt={p.name} loading={i < 6 ? "eager" : "lazy"} />
            <div class="overlay">
              <span class="cat">{p.category}</span>
              <strong>{p.name}</strong>
              <div class="price-row">
                <s>{p.originalPrice}</s>
                <span class="price">{p.price}</span>
                <span class="off">{p.discount}</span>
              </div>
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>

  <!-- Fade edges -->
  <div class="fade-left"></div>
  <div class="fade-right"></div>
</section>

<style>
  .img-carousel-section {
    position: relative;
    padding: 2rem 0 2.5rem;
    overflow: hidden;
    background: linear-gradient(180deg, #0f0f0f 0%, #0a130a 100%);
  }

  .label {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.6rem;
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: var(--gray-400);
    margin-bottom: 1.5rem;
  }
  .pulse {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--primary);
    animation: pulse 1.5s infinite;
    flex-shrink: 0;
  }
  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50%       { opacity: 0.4; transform: scale(0.7); }
  }

  .track-wrapper {
    overflow: hidden;
    cursor: grab;
    user-select: none;
  }
  .track-wrapper:active { cursor: grabbing; }

  .track {
    display: flex;
    gap: 1rem;
    width: max-content;
    animation: scroll 30s linear infinite;
  }
  .track:hover { animation-play-state: paused; }

  @keyframes scroll {
    0%   { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  .slide {
    flex: 0 0 220px;
    border-radius: 14px;
    overflow: hidden;
    border: 1px solid #222;
    transition: border-color 0.25s, transform 0.25s;
    display: block;
  }
  .slide:hover {
    border-color: var(--primary);
    transform: translateY(-4px);
  }

  .img-wrap {
    position: relative;
    aspect-ratio: 3/4;
    overflow: hidden;
    background: #111;
  }
  .img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }
  .slide:hover .img-wrap img { transform: scale(1.08); }

  .overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.92) 0%, rgba(0,0,0,0.2) 55%, transparent 100%);
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 1rem 0.9rem;
    gap: 0.3rem;
  }
  .cat {
    font-size: 0.65rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--primary);
    background: rgba(113, 192, 55,0.15);
    border: 1px solid rgba(113, 192, 55,0.3);
    padding: 0.15rem 0.5rem;
    border-radius: 999px;
    width: fit-content;
  }
  .overlay strong {
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--white);
    line-height: 1.3;
  }
  .price-row {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    flex-wrap: wrap;
    margin-top: 0.1rem;
  }
  .price-row s {
    font-size: 0.72rem;
    color: var(--gray-600);
  }
  .price {
    font-size: 0.95rem;
    font-weight: 800;
    color: var(--white);
  }
  .off {
    font-size: 0.68rem;
    font-weight: 700;
    background: var(--accent);
    color: #000;
    padding: 0.1rem 0.4rem;
    border-radius: 4px;
  }

  /* Fade nas bordas */
  .fade-left, .fade-right {
    position: absolute;
    top: 0;
    bottom: 0;
    width: 120px;
    pointer-events: none;
    z-index: 2;
  }
  .fade-left {
    left: 0;
    background: linear-gradient(to right, #0f0f0f, transparent);
  }
  .fade-right {
    right: 0;
    background: linear-gradient(to left, #0f0f0f, transparent);
  }
</style>
