---
import type { Product } from '../data/products';
interface Props { products: Product[]; }
const { products } = Astro.props;
---

<section class="carousel-section">
  <div class="section-header">
    <h2>Produtos em <span class="highlight">Destaque</span></h2>
    <p>Ofertas imperdíveis selecionadas para você</p>
  </div>

  <div class="carousel-wrapper">
    <button class="nav-btn prev" aria-label="Anterior">&#8249;</button>

    <div class="carousel-viewport" id="carousel">
      <div class="carousel-track" id="carouselTrack">
        {products.map((product, i) => (
          <div class="card" data-index={i}>
            {product.badge && <div class="badge">{product.badge}</div>}
            <div class="discount-tag">{product.discount}</div>

            <a href={`/produto/${product.slug}`} class="card-image">
              <img
                src={product.image}
                alt={product.name}
                loading={i < 3 ? "eager" : "lazy"}
              />
              <div class="category-pill">{product.category}</div>
            </a>

            <div class="card-body">
              <a href={`/produto/${product.slug}`} class="product-link">
                <h3 class="product-name">{product.name}</h3>
              </a>
              <p class="product-tagline">{product.tagline}</p>
              <p class="product-desc">{product.description}</p>

              <ul class="benefits">
                {product.benefits.map(b => (
                  <li><span class="check">✓</span>{b}</li>
                ))}
              </ul>

              <div class="rating">
                <span class="stars">{"★".repeat(Math.floor(product.rating))}{"☆".repeat(5 - Math.floor(product.rating))}</span>
                <span class="rating-value">{product.rating}</span>
                <span class="review-count">({product.reviews.toLocaleString('pt-BR')} avaliações)</span>
              </div>

              <div class="pricing">
                <span class="original-price">{product.originalPrice}</span>
                <span class="current-price">{product.price}</span>
              </div>

              <a href={`/produto/${product.slug}`} class="buy-btn">
                Ver Oferta →
              </a>
              <p class="guarantee">🔒 Compra 100% segura • 30 dias de garantia</p>
            </div>
          </div>
        ))}
      </div>
    </div>

    <button class="nav-btn next" aria-label="Próximo">&#8250;</button>
  </div>

  <div class="dots" id="dots">
    {products.map((_, i) => (
      <button class={`dot ${i === 0 ? 'active' : ''}`} data-dot={i} aria-label={`Produto ${i + 1}`}></button>
    ))}
  </div>
</section>

<style>
  .carousel-section {
    padding: 4rem 0;
    max-width: 1200px;
    margin: 0 auto;
    padding-left: 1.5rem;
    padding-right: 1.5rem;
  }
  .section-header {
    text-align: center;
    margin-bottom: 3rem;
  }
  .section-header h2 {
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    font-weight: 900;
    letter-spacing: -0.5px;
    margin-bottom: 0.5rem;
  }
  .highlight {
    background: linear-gradient(135deg, var(--primary), var(--accent));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .section-header p { color: var(--gray-400); font-size: 1.05rem; }

  .carousel-wrapper {
    position: relative;
    display: flex;
    align-items: center;
    gap: 1rem;
  }
  .carousel-viewport {
    overflow: hidden;
    flex: 1;
    border-radius: 16px;
  }
  .carousel-track {
    display: flex;
    transition: transform 0.45s cubic-bezier(0.4, 0, 0.2, 1);
    will-change: transform;
  }

  /* Card */
  .card {
    flex: 0 0 100%;
    background: linear-gradient(145deg, #1a1a1a, #141414);
    border: 1px solid #2a2a2a;
    border-radius: 16px;
    overflow: hidden;
    position: relative;
    display: flex;
    flex-direction: column;
    transition: border-color 0.3s;
  }
  @media (min-width: 768px) {
    .card { flex: 0 0 calc(50% - 0.5rem); margin-right: 1rem; }
    .card:last-child { margin-right: 0; }
  }
  @media (min-width: 1024px) {
    .card { flex: 0 0 calc(33.333% - 0.667rem); }
  }
  .card:hover { border-color: var(--primary); }

  .badge {
    position: absolute;
    top: 1rem;
    left: 1rem;
    z-index: 5;
    background: var(--primary);
    color: white;
    font-size: 0.72rem;
    font-weight: 700;
    padding: 0.3rem 0.75rem;
    border-radius: 999px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }
  .discount-tag {
    position: absolute;
    top: 1rem;
    right: 1rem;
    z-index: 5;
    background: var(--accent);
    color: #000;
    font-size: 0.8rem;
    font-weight: 800;
    padding: 0.3rem 0.6rem;
    border-radius: 8px;
  }

  .card-image {
    display: block;
    position: relative;
    aspect-ratio: 4/3;
    overflow: hidden;
    background: #111;
  }
  .product-link { display: block; }
  .product-link:hover .product-name { color: var(--primary); }
  .card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }
  .card:hover .card-image img { transform: scale(1.05); }
  .category-pill {
    position: absolute;
    bottom: 0.75rem;
    left: 0.75rem;
    background: rgba(0,0,0,0.7);
    backdrop-filter: blur(6px);
    border: 1px solid rgba(255,255,255,0.1);
    color: var(--gray-200);
    font-size: 0.72rem;
    padding: 0.25rem 0.6rem;
    border-radius: 999px;
  }

  .card-body {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    flex: 1;
  }
  .product-name {
    font-size: 1.2rem;
    font-weight: 800;
    line-height: 1.3;
    color: var(--white);
    transition: color 0.2s;
  }
  .product-tagline {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--primary);
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }
  .product-desc {
    font-size: 0.88rem;
    color: var(--gray-400);
    line-height: 1.65;
  }

  .benefits {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .benefits li {
    font-size: 0.85rem;
    color: var(--gray-200);
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .check {
    color: #22c55e;
    font-weight: 700;
    font-size: 0.9rem;
  }

  .rating {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    flex-wrap: wrap;
  }
  .stars { color: var(--accent); font-size: 0.9rem; }
  .rating-value { font-weight: 700; font-size: 0.9rem; }
  .review-count { color: var(--gray-400); font-size: 0.8rem; }

  .pricing {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    margin-top: auto;
  }
  .original-price {
    color: var(--gray-600);
    text-decoration: line-through;
    font-size: 0.9rem;
  }
  .current-price {
    font-size: 1.6rem;
    font-weight: 900;
    color: var(--white);
  }

  .buy-btn {
    display: block;
    background: linear-gradient(135deg, var(--primary), var(--primary-dark));
    color: white;
    font-size: 1rem;
    font-weight: 800;
    text-align: center;
    padding: 1rem;
    border-radius: 12px;
    letter-spacing: 0.5px;
    transition: all 0.25s ease;
    box-shadow: 0 4px 20px rgba(225,29,72,0.3);
  }
  .buy-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 30px rgba(225,29,72,0.5);
  }
  .buy-btn:active { transform: translateY(0); }

  .guarantee {
    text-align: center;
    font-size: 0.75rem;
    color: var(--gray-400);
  }

  /* Nav buttons */
  .nav-btn {
    background: rgba(255,255,255,0.05);
    border: 1px solid #2a2a2a;
    color: white;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    font-size: 1.75rem;
    line-height: 1;
    cursor: pointer;
    flex-shrink: 0;
    transition: all 0.2s;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .nav-btn:hover { background: var(--primary); border-color: var(--primary); }

  /* Dots */
  .dots {
    display: flex;
    justify-content: center;
    gap: 0.5rem;
    margin-top: 1.75rem;
  }
  .dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--gray-700);
    border: none;
    cursor: pointer;
    transition: all 0.25s;
    padding: 0;
  }
  .dot.active {
    background: var(--primary);
    width: 24px;
    border-radius: 4px;
  }

  @media (max-width: 640px) {
    .nav-btn { width: 38px; height: 38px; font-size: 1.4rem; }
  }
</style>

<script>
  const track = document.getElementById('carouselTrack') as HTMLElement;
  const dots = document.querySelectorAll('.dot');
  const prevBtn = document.querySelector('.nav-btn.prev') as HTMLButtonElement;
  const nextBtn = document.querySelector('.nav-btn.next') as HTMLButtonElement;

  let current = 0;
  let itemsPerView = 1;
  const cards = track.querySelectorAll('.card');
  const total = cards.length;

  function getItemsPerView() {
    if (window.innerWidth >= 1024) return 3;
    if (window.innerWidth >= 768) return 2;
    return 1;
  }

  function maxIndex() {
    return Math.max(0, total - itemsPerView);
  }

  function goTo(index: number) {
    itemsPerView = getItemsPerView();
    current = Math.max(0, Math.min(index, maxIndex()));
    const pct = (100 / itemsPerView) * current;
    track.style.transform = `translateX(-${pct}%)`;
    dots.forEach((d, i) => d.classList.toggle('active', i === current));
  }

  prevBtn.addEventListener('click', () => goTo(current - 1));
  nextBtn.addEventListener('click', () => goTo(current + 1));
  dots.forEach((d, i) => d.addEventListener('click', () => goTo(i)));

  window.addEventListener('resize', () => goTo(current));

  // Touch / swipe
  let startX = 0;
  track.addEventListener('touchstart', e => { startX = e.touches[0].clientX; }, { passive: true });
  track.addEventListener('touchend', e => {
    const diff = startX - e.changedTouches[0].clientX;
    if (Math.abs(diff) > 50) goTo(diff > 0 ? current + 1 : current - 1);
  });

  // Auto-play
  let autoplay = setInterval(() => goTo(current + 1 > maxIndex() ? 0 : current + 1), 5000);
  track.addEventListener('mouseenter', () => clearInterval(autoplay));
  track.addEventListener('mouseleave', () => {
    autoplay = setInterval(() => goTo(current + 1 > maxIndex() ? 0 : current + 1), 5000);
  });

  goTo(0);
</script>
