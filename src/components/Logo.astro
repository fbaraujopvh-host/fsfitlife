---
interface Props {
  size?: number;
}
const { size = 44 } = Astro.props;
---

<div class="brand">
  <svg
    width={size}
    height={size}
    viewBox="0 0 44 44"
    fill="none"
    xmlns="http://www.w3.org/2000/svg"
    class="logo-svg"
    aria-label="FS FitLife logo"
  >
    <!-- Halter na diagonal (canto sup. esq. -> inf. dir.) -->
    <g transform="rotate(45 22 22)">
      <rect x="5" y="19.5" width="34" height="5" rx="2.5" fill="#71c037" />
      <rect x="2" y="14" width="7" height="16" rx="3" fill="#f5901e" />
      <rect x="35" y="14" width="7" height="16" rx="3" fill="#f5901e" />
    </g>
    <!-- Halter na diagonal oposta (canto sup. dir. -> inf. esq.) -->
    <g transform="rotate(-45 22 22)">
      <rect x="5" y="19.5" width="34" height="5" rx="2.5" fill="#71c037" />
      <rect x="2" y="14" width="7" height="16" rx="3" fill="#f5901e" />
      <rect x="35" y="14" width="7" height="16" rx="3" fill="#f5901e" />
    </g>
  </svg>

  <div class="brand-text">
    <span class="name"><span class="fs-fit">FS Fit</span><span class="life">Life</span></span>
    <span class="slogan">Suplementos & Emagrecedores</span>
  </div>
</div>

<style>
  .brand {
    display: flex;
    align-items: center;
    gap: 0.65rem;
  }
  .logo-svg {
    flex-shrink: 0;
    filter: drop-shadow(0 2px 8px rgba(113, 192, 55, 0.4));
    transition: filter 0.3s;
  }
  .brand:hover .logo-svg {
    filter: drop-shadow(0 4px 16px rgba(113, 192, 55, 0.65));
  }
  .brand-text {
    display: flex;
    flex-direction: column;
    gap: 0.05rem;
    line-height: 1.15;
  }
  .name {
    font-size: 1.35rem;
    font-weight: 800;
    letter-spacing: -0.3px;
  }
  .fs-fit { color: var(--primary); }
  .life { color: var(--accent); }
  .slogan {
    font-size: 0.65rem;
    font-weight: 500;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--gray-400);
  }
</style>
