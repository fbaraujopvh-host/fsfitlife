---
const testimonials = [
  { name: "Ana Paula S.", text: "Recebi o produto muito rápido e o resultado foi incrível! Recomendo demais.", stars: 5, city: "São Paulo, SP" },
  { name: "Carlos M.", text: "Comprei pelo link do site e foi tudo perfeito. Atendimento nota 10!", stars: 5, city: "Rio de Janeiro, RJ" },
  { name: "Fernanda L.", text: "Produto de altíssima qualidade e preço justo. Já indiquei para toda família.", stars: 5, city: "Belo Horizonte, MG" },
  { name: "Roberto A.", text: "Entrega antes do prazo e produto idêntico às fotos. Muito satisfeito!", stars: 5, city: "Curitiba, PR" },
  { name: "Mariana T.", text: "Não achei esse preço em lugar nenhum. Garanti na hora sem arrependimento.", stars: 5, city: "Fortaleza, CE" },
  { name: "Lucas P.", text: "Qualidade impressionante pelo preço. Voltarei a comprar com certeza.", stars: 5, city: "Porto Alegre, RS" },
];
---

<section class="testimonials">
  <div class="container">
    <h2>O que nossos <span class="highlight">clientes dizem</span></h2>
    <div class="grid">
      {testimonials.map(t => (
        <div class="card">
          <div class="stars">{"★".repeat(t.stars)}</div>
          <p>"{t.text}"</p>
          <div class="author">
            <div class="avatar">{t.name[0]}</div>
            <div>
              <strong>{t.name}</strong>
              <span>{t.city}</span>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .testimonials {
    background: #0a0a0a;
    padding: 4rem 0;
  }
  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }
  h2 {
    font-size: clamp(1.6rem, 3.5vw, 2.5rem);
    font-weight: 900;
    text-align: center;
    margin-bottom: 2.5rem;
    letter-spacing: -0.5px;
  }
  .highlight {
    background: linear-gradient(135deg, var(--primary), var(--accent));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.25rem;
  }
  .card {
    background: #141414;
    border: 1px solid #222;
    border-radius: 14px;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    transition: border-color 0.25s;
  }
  .card:hover { border-color: #444; }
  .stars { color: var(--accent); font-size: 1rem; }
  p { font-size: 0.9rem; color: var(--gray-400); line-height: 1.65; font-style: italic; }
  .author { display: flex; align-items: center; gap: 0.75rem; margin-top: auto; }
  .avatar {
    width: 38px;
    height: 38px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--primary), var(--accent));
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 0.9rem;
    flex-shrink: 0;
  }
  .author div { display: flex; flex-direction: column; }
  strong { font-size: 0.85rem; font-weight: 700; }
  span { font-size: 0.75rem; color: var(--gray-400); }
</style>
