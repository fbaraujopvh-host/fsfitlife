---
<section class="trust">
  <div class="container">
    <div class="trust-item">
      <span class="icon">🔒</span>
      <div>
        <strong>Compra Segura</strong>
        <span>Ambiente 100% protegido</span>
      </div>
    </div>
    <div class="trust-item">
      <span class="icon">📦</span>
      <div>
        <strong>Entrega Garantida</strong>
        <span>Rastreamento em tempo real</span>
      </div>
    </div>
    <div class="trust-item">
      <span class="icon">💳</span>
      <div>
        <strong>Parcelamento</strong>
        <span>Em até 12x sem juros</span>
      </div>
    </div>
    <div class="trust-item">
      <span class="icon">↩️</span>
      <div>
        <strong>30 dias de garantia</strong>
        <span>Devolução sem perguntas</span>
      </div>
    </div>
  </div>
</section>

<style>
  .trust {
    background: linear-gradient(135deg, #111, #1a1a1a);
    border-top: 1px solid #2a2a2a;
    border-bottom: 1px solid #2a2a2a;
    padding: 1.75rem 0;
  }
  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 2.5rem;
    flex-wrap: wrap;
  }
  .trust-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  .icon { font-size: 1.75rem; }
  .trust-item div {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }
  strong {
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--white);
    line-height: 1.2;
  }
  span {
    font-size: 0.75rem;
    color: var(--gray-400);
  }
</style>
