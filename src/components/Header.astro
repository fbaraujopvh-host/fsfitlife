---
import Logo from './Logo.astro';
---
<header class="header">
  <div class="container">
    <Logo />
    <p class="tagline">Suplementos e emagrecedores selecionados para você</p>
  </div>
</header>

<style>
  .header {
    background: linear-gradient(135deg, #0f0f0f 0%, #1a0a0a 100%);
    border-bottom: 2px solid var(--primary);
    padding: 1rem 0;
    position: sticky;
    top: 0;
    z-index: 100;
    backdrop-filter: blur(10px);
  }
  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }
  .tagline {
    font-size: 0.85rem;
    color: var(--gray-400);
    font-style: italic;
  }
  @media (max-width: 600px) {
    .tagline { display: none; }
  }
</style>
